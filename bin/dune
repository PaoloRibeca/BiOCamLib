(env
 (dev
  (ocamlopt_flags (:standard -g)))
 (dev-static
  (ocamlopt_flags (:standard -g -ccopt -static)))
 (release
  (ocamlopt_flags (:standard -O3 -ccopt -O3)))
 (release-static
  (ocamlopt_flags (:standard -O3 -ccopt -O3 -ccopt -static))))

(executables
 (public_names Parallel Octopus RC FASTools Annotools TREx Cophenetic Yggdrasill)
 (names Parallel Octopus RC FASTools Annotools TREx Cophenetic Yggdrasill)
 (libraries str unix BiOCamLib zarith))

(install
 (section bin)
 (files
  (Parallel.exe as Parallel)
  (Octopus.exe as Octopus)
  (RC.exe as RC)
  (FASTools.exe as FASTools)
  (Annotools.exe as Annotools)
  (TREx.exe as TREx)
  (Cophenetic.exe as Cophenetic)
  (Yggdrasill.exe as Yggdrasill)))
